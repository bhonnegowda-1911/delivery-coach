# Frontend (Vite) environment. Copy to `.env.local` and fill in. All vars must be prefixed VITE_.

# Clerk publishable key (pk_test_… in dev, pk_live_… in prod). When set, the app shows a login wall
# and sends the Clerk session token to the backend. Leave UNSET for local dev to run as a single
# user with no login (the server falls back to DEV_USER_ID).
VITE_CLERK_PUBLISHABLE_KEY=

# Point the SPA at a remote API origin. Default (empty) = same-origin via the Vite dev proxy / the
# production reverse proxy. Only set this if the API is served from a different origin.
VITE_API_BASE=
