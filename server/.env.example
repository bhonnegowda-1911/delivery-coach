# Copy to server/.env and fill in. Defaults below match docker-compose.

# Auth (Clerk). Set CLERK_SECRET_KEY to enforce auth: every /api request must carry a valid Clerk
# session, and data is scoped per user. Leave it UNSET for local dev to run as a single user —
# every request is treated as DEV_USER_ID (default 'local-dev'), no login required.
CLERK_SECRET_KEY=
# The user id used for all requests when auth is disabled (local dev only). Also the id to pass to
# the backfill script if you want existing data to land under this user.
DEV_USER_ID=local-dev

# Provider keys — optional server-side fallback. With multi-user/BYOK, leave these EMPTY so the
# server is never an open wallet; each user brings their own keys in the browser (Settings).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# Postgres (docker-compose default)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/delivery_coach

# MinIO / S3 (docker-compose default)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=career-coach

PORT=8787
