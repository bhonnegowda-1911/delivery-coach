# Copy to server/.env and fill in the provider keys. Defaults below match docker-compose.

# Provider keys — live ONLY here on the server now (no longer in the browser).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Postgres (docker-compose default)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/delivery_coach

# MinIO / S3 (docker-compose default)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=career-coach

PORT=8787
